{
  "name": "dulceria",
  "version": "0.1.0",
  "description": "Dulceria — fine vegan chocolates production planning.",
  "author": "Dulceria GmbH",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/manuelatorres-cmd/dulceria-production.git"
  },
  "keywords": [
    "chocolatier",
    "chocolate",
    "production",
    "recipe-management",
    "ganache",
    "nextjs",
    "supabase"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "docs:screenshots": "PLAYWRIGHT_DOCS=1 playwright test e2e/docs-screenshots.spec.ts",
    "audit": "npm audit --audit-level=moderate"
  },
  "type": "module",
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/supabase-js": "^2.103.3",
    "@tanstack/react-query": "^5.99.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "lucide-react": "^1.8.0",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.1.4",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
