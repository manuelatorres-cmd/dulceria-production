# ──────────────────────────────────────────────────────────────
# Dulceria — Environment Variables
# ──────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in the values you need.
# All variables are optional — the app runs fully local without any of them.

# Dexie Cloud — multi-device sync (optional)
# Sign up at https://dexie.org/cloud/ to get a database URL.
# When unset the app uses local-only IndexedDB with no login screen.
NEXT_PUBLIC_DEXIE_CLOUD_URL=
